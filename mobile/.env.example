# Copy to .env in this folder (mobile/.env). Restart Metro after changes: npx expo start --clear
# Names must match exactly (do not use EXPO_PUBLIC_SUPABASE_MAPBOX_TOKEN or other merged typos).

# API URL from Supabase → Project Settings → API → Project URL (https://xxxxx.supabase.co)
# NOT the dashboard link (https://supabase.com/dashboard/project/...)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ..._or_sb_publishable_...

# Mapbox public access token (runtime map)
EXPO_PUBLIC_MAPBOX_TOKEN=pk.ey...

# Optional (native prebuild / EAS only): do NOT put in app.config.js — use this env var name.
# Set in shell before `npx expo prebuild` or as an EAS Secret. Many Mapbox SDK versions no longer require it.
# RNMAPBOX_MAPS_DOWNLOAD_TOKEN=
